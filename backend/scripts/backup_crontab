# Daily full backup at 2:00 AM
0 2 * * * root /usr/local/bin/python /app/scripts/backup_scheduler.py --type full >> /var/log/backup.log 2>&1
# Hourly WAL archiving (continuous)
0 * * * * root /usr/local/bin/python /app/scripts/backup_scheduler.py --type wal >> /var/log/backup.log 2>&1
# Backup verification every Sunday at 3:00 AM
0 3 * * 0 root /usr/local/bin/python /app/scripts/backup_scheduler.py --type verify >> /var/log/backup.log 2>&1
# Cleanup old backups every 1st of month at 4:00 AM
0 4 1 * * root /usr/local/bin/python /app/scripts/backup_scheduler.py --type cleanup >> /var/log/backup.log 2>&1
