# ──────────────────────────────────────────────
# Blackbox BOM — Environment Configuration
# ──────────────────────────────────────────────
# Copy to .env and fill in your values.

# Environment: development, staging, production
ENVIRONMENT=development

# PostgreSQL — REQUIRED. Generate your own with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=bom_user
POSTGRES_PASSWORD=
POSTGRES_DB=bom_db
POSTGRES_SERVER=127.0.0.1
POSTGRES_PORT=5432

# Redis (optional, falls back to in-memory). If running via
# backend/docker-compose.yml, the redis container always runs with
# --requirepass, so REDIS_PASSWORD below is REQUIRED for that stack —
# generate your own with the same command as above. When set, also fill
# in REDIS_URL with the matching password, e.g.:
#   REDIS_URL=redis://:<same-value-as-REDIS_PASSWORD>@127.0.0.1:6379/0
REDIS_PASSWORD=
REDIS_URL=

# Security Secrets (generate with: python -c "import secrets; print(secrets.token_urlsafe(32))")
SECRET_KEY=
ENCRYPTION_KEY=

# CORS — production: set to your frontend domain(s) as JSON array
# BACKEND_CORS_ORIGINS=["https://app.yourdomain.com"]

# S3/MinIO (optional)
S3_ENDPOINT=http://127.0.0.1:9000
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=bom-documents

# SSO (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
SSO_REDIRECT_URI=http://localhost:3000/auth/callback

# Email / SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@blackbox-bom.com

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_AUTH_PER_MINUTE=10

# Backup (local + S3 offsite)
BACKUP_DIR=./backups
BACKUP_SCHEDULE_HOURS=6
BACKUP_MIN_DISK_GB=5

# WAL archive directory — MUST match postgresql.conf's archive_command target
# (see backend/postgresql.conf and scripts/pitr_restore.py) or PITR restores
# will silently fail to find archived WAL segments. Leave as the default when
# running via docker-compose (the volume is mounted at this exact path).
WAL_ARCHIVE_DIR=/var/lib/postgresql/wal_archive

# S3/MinIO for offsite backup storage (uses S3_ENDPOINT, S3_ACCESS_KEY, S3_SECRET_KEY, S3_BUCKET above)
# Trigger S3 backup via: POST /api/v1/backup/create?storage_type=s3
# Or CLI: python scripts/backup_cron.py --dual-storage

# Vault (optional)
VAULT_ADDR=
VAULT_TOKEN=
VAULT_SECRET_PATH=secret/data/bom-tool
