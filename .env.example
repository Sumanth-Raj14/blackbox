# ──────────────────────────────────────────────────────────────────────────
# Blackbox BOM — Local Deployment Environment (docker compose)
# ──────────────────────────────────────────────────────────────────────────
# Used by the root docker-compose.yml to bring the whole stack up with ONE
# command, entirely on this machine (local-first: no cloud dependency).
#
#   1. cp .env.example .env
#   2. Replace every value below with your own (see the generator command
#      next to each secret) — do NOT ship the defaults below to production.
#   3. docker compose up --build
#   4. Open http://localhost  (nginx serves the SPA and proxies /api + /ws
#      to the backend — see frontend/nginx.conf)
#
# `.env` is gitignored — real secrets never get committed. This file only
# ever holds placeholder values.

# ── Environment ─────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL ──────────────────────────────────────────────────────────
POSTGRES_USER=bom_user
POSTGRES_PASSWORD=nMopt7gODib9FeBt0w8GxvI5CUS1Xf_S7H4PShZeWg8
POSTGRES_DB=bom_db

# ── Redis (optional — cache/rate-limit falls back to in-memory if unset) ─
REDIS_PASSWORD=FEAu-M1Ne_QbEk2R60l000rqIkzV7S14Og23Txvjykc

# ── App secrets — generate real values with:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=Rua1N2kM7TEHk1b4A-SkyFByVmC8ANLq_generate_your_own_replace_me
ENCRYPTION_KEY=QHQrI_g4L-hTDmKb3xD0mA58vvoXrYw5_generate_your_own_replace_me

# ── S3/MinIO (optional — NOT used by the default local-first stack, which
# stores documents on the local filesystem). The backend validates this
# value is non-empty at startup regardless, so it must be set even if you
# never enable S3 — any non-trivial placeholder works.
S3_ACCESS_KEY=local-unused
S3_SECRET_KEY=dbutbqJ7_rjL1HgLxtAk92_zzuO5rtWj_generate_your_own_replace_me

# ── Postgres Row-Level Security (opt-in defense-in-depth; off by default,
# no-op unless True — app-layer tenant isolation is the primary mechanism) ─
ENABLE_RLS=false

# ── First-run RBAC bootstrap ────────────────────────────────────────────
# Seeds the default roles/permissions catalog ONLY when the roles table is
# empty (fresh database) — safe to leave on for every restart.
SEED_RBAC_ON_START=true

# ── Ports (change if 80/8000/5432/6379 are already taken on this host) ──
FRONTEND_PORT=80
BACKEND_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
