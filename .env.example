# ──────────────────────────────────────────────────────────────────────────
# Blackbox BOM — Local Deployment Environment (docker compose)
# ──────────────────────────────────────────────────────────────────────────
# Used by the root docker-compose.yml to bring the whole stack up with ONE
# command, entirely on this machine (local-first: no cloud dependency).
#
#   1. cp .env.example .env
#   2. Fill in EVERY secret below with your own value (see the generator
#      command next to each one) — this file intentionally ships them EMPTY,
#      not with placeholder text. `docker compose up` will refuse to start
#      (with a "variable is required" error naming the missing var) until you
#      do, on purpose: a fixed, publicly-known placeholder committed to git
#      would otherwise let anyone forge auth tokens or decrypt data. The
#      Windows installer (install.ps1 / install.bat) does this step for you
#      automatically with freshly generated random secrets — this manual path
#      is only for non-Windows / non-installer setups.
#   3. docker compose up --build
#   4. Open http://localhost  (nginx serves the SPA and proxies /api + /ws
#      to the backend — see frontend/nginx.conf)
#
# `.env` is gitignored — real secrets never get committed. This file only
# ever holds placeholder values (or none, for the secrets below).

# ── Environment ─────────────────────────────────────────────────────────
ENVIRONMENT=development

# ── PostgreSQL — REQUIRED. Generate your own with:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
POSTGRES_USER=bom_user
POSTGRES_PASSWORD=
POSTGRES_DB=bom_db

# ── Redis — REQUIRED by this docker-compose stack (the redis container
# always runs with --requirepass). Generate your own with the same command
# as above.
REDIS_PASSWORD=

# ── App secrets — REQUIRED. Generate real values with:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=
ENCRYPTION_KEY=

# ── S3/MinIO (NOT used by the default local-first stack, which stores
# documents on the local filesystem) — but the backend validates this value
# is non-empty at startup regardless, so it is still REQUIRED even if you
# never enable S3. Any non-trivial value works, e.g.:
#      python -c "import secrets; print(secrets.token_urlsafe(32))"
S3_ACCESS_KEY=local-unused
S3_SECRET_KEY=

# ── Postgres Row-Level Security (opt-in defense-in-depth; off by default,
# no-op unless True — app-layer tenant isolation is the primary mechanism) ─
ENABLE_RLS=false

# ── First-run RBAC bootstrap ────────────────────────────────────────────
# Seeds the default roles/permissions catalog ONLY when the roles table is
# empty (fresh database) — safe to leave on for every restart.
SEED_RBAC_ON_START=true

# ── Ports (change if 80/8000/5432/6379 are already taken on this host) ──
FRONTEND_PORT=80
BACKEND_PORT=8000
POSTGRES_HOST_PORT=5432
REDIS_HOST_PORT=6379
