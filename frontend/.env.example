# Blackbox BOM — Environment Configuration

# Server port (default: 3001)
PORT=3001

# API backend URL (only needed if running backend separately)
VITE_API_URL=http://localhost:8000

# Conversion rate for USD → INR (default: 83)
# VITE_USD_TO_INR=83

# When true, uses static mock data (window.BOM_DATA) instead of connecting to the API
# VITE_MOCK_MODE=false
